# SportIL local/deployment environment template.
# Copy values into your platform secret manager; do not commit real secrets.

# API
PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://sportil:sportil@localhost:5432/sportil
SPORTIL_ALLOWED_ORIGINS=http://localhost:3001
SPORTIL_DEV_AUTH=true

# Web
NEXT_PUBLIC_SPORTIL_API_BASE_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SPORTIL_SITE_URL=http://localhost:3001

# Cloudflare Workers deployment for apps/web.
# Set these in your shell/CI or Cloudflare dashboard, not in source control.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Production examples:
# NODE_ENV=production
# SPORTIL_ALLOWED_ORIGINS=https://gosport.co.il,https://www.gosport.co.il
# NEXT_PUBLIC_SPORTIL_API_BASE_URL=https://api.gosport.co.il/api/v1
# NEXT_PUBLIC_SPORTIL_SITE_URL=https://gosport.co.il
# SPORTIL_DEV_AUTH=false
